{
  "name": "planovna",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @planovna/web run dev",
    "dev:api": "npm --workspace @planovna/api run start:dev",
    "build": "npm run -ws build",
    "test": "npm run -ws test",
    "gate:local": "bash ./scripts/ci_local_gate.sh"
  }
}
